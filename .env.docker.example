# OnlyFix - Docker Environment Configuration

APP_NAME=OnlyFix
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://onlyfix.local

# Application
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

# Security
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (MySQL - Docker)
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=onlyfix
DB_USERNAME=onlyfix
DB_PASSWORD=onlyfixSecurePass456!

# Session & Cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database

# Queue
QUEUE_CONNECTION=database

# Filesystem
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Email (Mailpit - Docker)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@onlyfix.local"
MAIL_FROM_NAME="${APP_NAME}"

# Vite
VITE_APP_NAME="${APP_NAME}"
VITE_DEV_SERVER_URL=http://node.onlyfix.local:5173
